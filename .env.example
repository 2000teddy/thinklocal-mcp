# thinklocal-mcp Credentials
# Kopiere diese Datei nach .env und trage deine Werte ein:
#   cp .env.example .env
#
# Die .env-Datei ist in .gitignore — wird nie ins Repository uebertragen.
# Beim Bootstrap werden die Credentials verschluesselt im Vault gespeichert.

# GitHub (fuer automatischen Git Push der Agents)
GITHUB_TOKEN=ghp_...
GITHUB_USER=dein-github-username
GITHUB_EMAIL=dein@email.com

# Telegram (fuer Agent-zu-Agent-Kommunikation)
TELEGRAM_BOT_TOKEN=123456:ABC...

# InfluxDB (wenn vorhanden)
INFLUXDB_USERNAME=
INFLUXDB_PASSWORD=

# Weitere Credentials nach Bedarf
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
