{
  "name": "@thinklocal/daemon",
  "version": "0.1.0",
  "description": "thinklocal-mcp mesh daemon — peer discovery, agent cards, heartbeat",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.5",
    "@fastify/websocket": "^11.2.0",
    "@iarna/toml": "^3.0.0",
    "@niomon/spake2": "^1.0.4",
    "@noble/ed25519": "^2.2.0",
    "better-sqlite3": "^11.7.0",
    "bonjour-service": "^1.3.0",
    "cbor-x": "^1.6.4",
    "fastify": "^5.2.0",
    "node-forge": "^1.4.0",
    "pino": "^9.6.0",
    "systeminformation": "^5.23.0",
    "undici": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/node-forge": "^1.3.14",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
