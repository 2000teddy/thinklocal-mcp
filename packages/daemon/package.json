    "@chainsafe/libp2p-yamux": "^7.0.4",
    "@fastify/jwt": "^10.0.0",
    "@fastify/websocket": "^11.2.0",
    "@iarna/toml": "^3.0.0",
    "@libp2p/identify": "^3.0.38",
    "@libp2p/mdns": "^11.0.43",
    "@libp2p/ping": "^2.0.37",
    "@libp2p/tcp": "^10.1.19",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@niomon/spake2": "^1.0.4",
    "@noble/ed25519": "^2.2.0",
    "better-sqlite3": "^11.7.0",
    "bonjour-service": "^1.3.0",
    "cbor-x": "^1.6.4",
    "fastify": "^5.2.0",
    "graphql": "^16.13.2",
    "mercurius": "^16.9.0",
    "libp2p": "^2.10.0",
    "node-forge": "^1.4.0",
    "node-telegram-bot-api": "^0.67.0",
    "pino": "^9.6.0",
    "shamir": "^0.7.1",
    "systeminformation": "^5.23.0",
